# Corporate proxy (internal). Copy into .env in project root or merge with your .env.
# Compose defaults (NO_PROXY): docker/proxy.defaults.yml
#
# HTTP/HTTPS through Squid (same URL for both):
HTTP_PROXY=http://10.234.111.10:3128
HTTPS_PROXY=http://10.234.111.10:3128
NO_PROXY=localhost,127.0.0.1,host.docker.internal,.local,.eurochem.ru,.tgp.eurochem.ru

# Skip apt during image build when deb.debian.org is blocked (default in compose).
SKIP_APT_PACKAGES=1

# Full stack (LibreOffice + Tesseract) when apt is allowed through proxy:
# SKIP_APT_PACKAGES=0

# DNS for containers (required on corp LAN for npm/apt during build):
#   docker compose -f docker-compose.yml -f docker-compose.corp-network.yml up --build
#
# Docker Desktop engine proxy (optional, helps build stages):
#   merge docker/daemon.corp-proxy.json.example into Docker Engine settings
