# HTTP proxy (optional). Copy into .env in project root or merge with your .env.
# Compose defaults (NO_PROXY): docker/proxy.defaults.yml
#
# HTTP/HTTPS through corporate Squid (same URL for both):
# HTTP_PROXY=http://proxy.example.com:3128
# HTTPS_PROXY=http://proxy.example.com:3128
# NO_PROXY=localhost,127.0.0.1,host.docker.internal,.local

# Skip apt during image build when deb.debian.org is blocked (default in compose).
SKIP_APT_PACKAGES=1

# Full stack (LibreOffice + Tesseract) when apt is allowed through proxy:
# SKIP_APT_PACKAGES=0

# Corporate DNS for containers (see docker-compose.corp-network.yml).
# On Windows: ipconfig /all → DNS Servers of active adapter (VPN/LAN).
# CORP_DNS=192.0.2.1

# Windows Docker Desktop: if pip/npm fail with proxy hostname resolution:
#   .\scripts\powershell\Setup-DockerCorp.ps1 -Apply
#   docker compose -f docker-compose.yml -f docker-compose.corp-windows.yml up --build

# DNS for containers:
#   docker compose -f docker-compose.yml -f docker-compose.corp-network.yml up --build
#
# Docker Desktop engine (Settings → Docker Engine): merge docker/daemon.proxy.json.example
# Set "dns" to the same CORP_DNS value as in .env.
