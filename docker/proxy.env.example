# Corporate proxy (internal). Copy into .env in project root or merge with your .env.
# Compose defaults (NO_PROXY): docker/proxy.defaults.yml
#
# HTTP/HTTPS through corporate Squid (same URL for both).
# Examples:
#   TGP: http://10.234.111.10:3128
#   USL: http://usl-kwts02.usl.eurochem.ru:3128
#   USL (Windows Docker — if hostname fails in containers): http://10.x.x.x:3128
HTTP_PROXY=http://10.234.111.10:3128
HTTPS_PROXY=http://10.234.111.10:3128
NO_PROXY=localhost,127.0.0.1,host.docker.internal,.local,.eurochem.ru,.tgp.eurochem.ru,.usl.eurochem.ru

# Corporate DNS for containers (see docker-compose.corp-network.yml).
# On Windows: ipconfig /all → DNS Servers of active adapter (VPN/LAN).
# CORP_DNS=10.x.x.x

# Windows Docker Desktop: if pip/npm fail with "Temporary failure in name resolution"
# for the proxy host, either use IP in HTTP_PROXY above, or:
# CORP_PROXY_HOST=usl-kwts02.usl.eurochem.ru
# CORP_PROXY_IP=10.x.x.x
# and add -f docker-compose.corp-proxy-host.yml to docker compose command.

# Skip apt during image build when deb.debian.org is blocked (default in compose).
SKIP_APT_PACKAGES=1

# Full stack (LibreOffice + Tesseract) when apt is allowed through proxy:
# SKIP_APT_PACKAGES=0

# DNS for containers:
#   docker compose -f docker-compose.yml -f docker-compose.corp-network.yml up --build
#
# Docker Desktop engine (Settings → Docker Engine): merge docker/daemon.corp-proxy.json.example
# Set "dns" to the same CORP_DNS value as in .env.
