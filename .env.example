# Docker на Mac + /Volumes/Внешний/… (кириллица): bind-mount ломается — используйте
#   docker compose up --build          (код в образе, без mount)
# Hot-reload только из пути без кириллицы, напр. ~/Projects/PTE-DocEx:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build

# For x64 Linux VPS when building images on Apple Silicon:
# DOCKER_PLATFORM=linux/amd64

# If Docker build fails with "Temporary failure in name resolution" (Windows):
# 1) Docker Desktop → Settings → Docker Engine → merge docker/daemon.json.example
# 2) docker compose -f docker-compose.yml -f docker-compose.corp-network.yml up --build

# Corporate network (proxy + DNS in containers):
#   See docker/proxy.env.example — copy HTTP_PROXY/HTTPS_PROXY/NO_PROXY into this file.
#   Internal proxy: http://10.234.111.10:3128
#   DNS in containers: docker compose -f docker-compose.yml -f docker-compose.corp-network.yml up --build
# HTTP_PROXY=http://10.234.111.10:3128
# HTTPS_PROXY=http://10.234.111.10:3128
# NO_PROXY=localhost,127.0.0.1,host.docker.internal,.local,.eurochem.ru,.tgp.eurochem.ru
# SKIP_APT_PACKAGES=1

# --- Ollama ---
# Docker Desktop (macOS/Windows): backend in container → Ollama on host
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Host mode (backend runs locally): use 127.0.0.1
# OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=180

# --- LanguageTool ---
# Docker mode (backend in container):
# LANGUAGETOOL_URL=http://languagetool:8010/v2/check
# Host mode (backend locally, LT in docker compose):
# LANGUAGETOOL_URL=http://127.0.0.1:8010/v2/check

LANGUAGETOOL_LANGUAGE=ru-RU
OCR_LANGUAGE=rus+eng
OCR_DPI=300
OCR_PSM_MODES=3,6
OCR_USE_TEXT_LAYER=true
OCR_MIN_TEXT_LAYER_CHARS=40
DOCUMENT_SIMILARITY_THRESHOLD=0.985
PAGE_SIMILARITY_WARNING_THRESHOLD=0.95
FZ63_CHECK_ENABLED=true
FZ63_REQUIRE_CRL=true
FZ63_CRL_TIMEOUT_SECONDS=12

MAX_UPLOAD_MB=150

# --- RAG Platform (раздел «Анализ проекта») ---
# Полный Docker-стек (docker compose up): RAG внутри compose, сервис rag-api
RAG_ENABLED=true
RAG_API_URL=http://rag-api:8100
# Только PTE core (docker compose -f docker-compose.core.yml up) или backend на хосте:
# RAG_API_URL=http://host.docker.internal:8100
# RAG_API_URL=http://127.0.0.1:8100
RAG_HTTP_TIMEOUT_SECONDS=120
RAG_COLLECTION_PROJECT_ANALYSIS=project_analysis_text

# Порты RAG-инфраструктуры (docker/rag.compose.yml)
RAG_API_PORT=8100
RAG_ADMIN_UI_PORT=5174
RAG_ADMIN_VITE_API_URL=http://127.0.0.1:8100
# 5433/6380 — чтобы не конфликтовать с PostgreSQL/Redis на хосте (5432/6379)
POSTGRES_PORT=5433
REDIS_PORT=6380
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
QDRANT_PORT=6333
POSTGRES_DB=rag_platform
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_secret
MINIO_ACCESS_KEY=ragminio
MINIO_SECRET_KEY=ragminio_secret
MINIO_BUCKET=documents
QDRANT_COLLECTION_PROJECT_ANALYSIS=project_analysis_text
RAG_PARSER_PRIMARY=pypdf
RAG_PARSER_FALLBACK=pypdf
RAG_WORKER_CONCURRENCY=2
RAG_LOG_LEVEL=INFO

# --- Парсер «Задание на проектирование» (design-assignment-parser) ---
DESIGN_ASSIGNMENT_PARSER_PORT=8200
ACTIVE_MINSTROY_DESIGN_ASSIGNMENT_SCHEMA_VERSION=v01_00
