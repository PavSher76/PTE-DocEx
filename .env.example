OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=180
LANGUAGETOOL_LANGUAGE=ru-RU
OCR_LANGUAGE=rus+eng
OCR_DPI=300
OCR_PSM_MODES=3,6
OCR_USE_TEXT_LAYER=true
OCR_MIN_TEXT_LAYER_CHARS=40
DOCUMENT_SIMILARITY_THRESHOLD=0.985
PAGE_SIMILARITY_WARNING_THRESHOLD=0.95
FZ63_CHECK_ENABLED=true
FZ63_REQUIRE_CRL=true
FZ63_CRL_TIMEOUT_SECONDS=12
