# --- API / Worker ---
API_HOST=0.0.0.0
API_PORT=8100
WORKER_CONCURRENCY=2
LOG_LEVEL=INFO

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_platform
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_secret
DATABASE_URL=postgresql+psycopg://rag:rag_secret@localhost:5432/rag_platform

# --- Redis (RQ) ---
REDIS_URL=redis://localhost:6379/0

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=ragminio
MINIO_SECRET_KEY=ragminio_secret
MINIO_BUCKET=documents
MINIO_SECURE=false
MINIO_REGION=us-east-1

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_TEXT=project_documents_text
QDRANT_COLLECTION_DRAWINGS_TEXT=project_drawings_text
QDRANT_COLLECTION_DRAWINGS_VISUAL=project_drawings_visual
QDRANT_COLLECTION_REQUIREMENTS=project_requirements
QDRANT_COLLECTION_NORMATIVE=normative_documents
QDRANT_COLLECTION_PROJECT_ANALYSIS=project_analysis_text
QDRANT_COLLECTION_PROJECT_ANALYSIS_DRAWINGS=project_analysis_drawings_text

# --- Embeddings (Sprint 1: dense only) ---
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384
EMBEDDING_USE_SENTENCE_TRANSFORMERS=false

PARSER_PRIMARY=docling
PARSER_FALLBACK=unstructured

HYBRID_SEARCH_ENABLED=true
RERANK_ENABLED=true

QDRANT_COLLECTION_DRAWINGS_TEXT=project_drawings_text
DRAWING_RENDER_DPI=200
DRAWING_OCR_ENABLED=true
DRAWING_INDEX_ENABLED=true
DRAWING_PROCESS_ALL_PDF_PAGES=false
OCR_LANGUAGE=rus+eng
OCR_DPI=300
OCR_PSM_MODES=3,6
OCR_MIN_TEXT_LAYER_CHARS=40

# --- LLM (этап 8 / Sprint 5) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=120
LLM_ENABLED=true
OPENAI_API_BASE=
OPENAI_API_KEY=

# --- Пилот ИТЦ (Sprint 5) ---
PILOT_DEFAULT_PROJECT_ID=PTE-ITC-450

# --- Processing ---
MAX_UPLOAD_MB=200
# project_analysis → pte_pdf (fitz+OCR); прочие PDF — parser_primary/fallback
PARSER_PRIMARY=pypdf
PARSER_FALLBACK=pypdf
