# Скопируйте в корень репозитория как .env (setup-host.sh делает это автоматически).
# Значения ниже — для запуска backend/frontend на хосте (не в Docker).

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=180
LANGUAGETOOL_URL=http://127.0.0.1:8010/v2/check
LANGUAGETOOL_LANGUAGE=ru-RU
DATABASE_URL=sqlite:///./storage/app.db
OCR_LANGUAGE=rus+eng
OCR_DPI=300
OCR_PSM_MODES=3,6
OCR_USE_TEXT_LAYER=true
OCR_MIN_TEXT_LAYER_CHARS=40
DOCUMENT_SIMILARITY_THRESHOLD=0.985
PAGE_SIMILARITY_WARNING_THRESHOLD=0.95
